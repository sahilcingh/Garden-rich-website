<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Delivery Policy | GardenRich</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body class="bg-zinc-50 font-sans antialiased">
    <%- include("partials/header") %>

    <div class="max-w-4xl mx-auto py-20 px-6">
        <h1 class="text-4xl font-black mb-10">Delivery Policy</h1>

        <div class="space-y-6">
            <div class="bg-green-50 border border-green-100 p-6 rounded-2xl flex items-center">
                <div class="w-12 h-12 bg-green-600 rounded-full flex items-center justify-center text-white mr-4 shrink-0">🚚</div>
                <p class="text-green-800 font-bold">Standard Delivery Window: 7 to 15 business days.</p>
            </div>

            <div class="grid md:grid-cols-2 gap-6">
                <div class="bg-white p-8 rounded-3xl border border-zinc-100 shadow-sm">
                    <h3 class="font-black text-xl mb-3">Order Processing</h3>
                    <p class="text-zinc-600 text-sm leading-relaxed">Every order undergoes a quality check and is typically dispatched within 48 to 72 hours of placement.</p>
                </div>

                <div class="bg-white p-8 rounded-3xl border border-zinc-100 shadow-sm">
                    <h3 class="font-black text-xl mb-3">Shipping Charges</h3>
                    <% 
                        const shippingCost = parseFloat(settings?.shipping_cost || 0);
                        const freeAbove = parseFloat(settings?.free_shipping_above || 0);
                    %>
                    <% if (shippingCost === 0) { %>
                        <p class="text-zinc-600 text-sm leading-relaxed">We are proud to offer <strong>Free Shipping</strong> on all orders nationwide. The price you see is exactly what you pay.</p>
                    <% } else if (freeAbove > 0) { %>
                        <p class="text-zinc-600 text-sm leading-relaxed">A shipping charge of <strong>Rs. <%= shippingCost %></strong> applies on orders below <strong>Rs. <%= freeAbove %></strong>. Orders above Rs. <%= freeAbove %> enjoy <strong class="text-green-600">Free Shipping</strong>!</p>
                    <% } else { %>
                        <p class="text-zinc-600 text-sm leading-relaxed">A flat shipping charge of <strong>Rs. <%= shippingCost %></strong> applies to all orders.</p>
                    <% } %>
                </div>

                <% if (parseFloat(settings?.minimum_order_value || 0) > 0) { %>
                <div class="bg-white p-8 rounded-3xl border border-zinc-100 shadow-sm">
                    <h3 class="font-black text-xl mb-3">Minimum Order</h3>
                    <p class="text-zinc-600 text-sm leading-relaxed">A minimum order value of <strong>Rs. <%= settings.minimum_order_value %></strong> is required to place an order.</p>
                </div>
                <% } %>
            </div>
        </div>
    </div>

    <%- include("partials/footer") %>
</body>
</html>