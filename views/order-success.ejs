<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Order Placed | GardenRich</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body class="bg-zinc-50 font-sans antialiased text-zinc-900">
    <%- include("partials/header") %>

    <div class="max-w-xl mx-auto py-16 px-6 pb-24">

        <!-- Success Header -->
        <div class="text-center mb-8">
            <div class="w-20 h-20 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-5">
                <svg class="w-10 h-10 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                </svg>
            </div>
            <h1 class="text-3xl font-black text-zinc-900 mb-2">Order Placed!</h1>
            <p class="text-zinc-500 font-medium">
                Thank you! We'll deliver it soon.<br>
                <span class="text-xs font-bold text-zinc-400 font-mono">#<%= order.id.toString().slice(0, 8).toUpperCase() %></span>
            </p>
        </div>

        <!-- Items -->
        <div class="bg-white rounded-2xl border border-zinc-100 shadow-sm p-6 mb-4">
            <p class="text-xs font-black uppercase tracking-widest text-zinc-400 mb-4">Items Ordered</p>

            <% if (order.order_items && order.order_items.length > 0) { %>
            <div class="space-y-3">
                <% order.order_items.forEach((item, idx) => { %>
                <div class="flex items-center gap-3 <%= idx < order.order_items.length - 1 ? 'pb-3 border-b border-zinc-50' : '' %>">
                    <!-- Image -->
                    <% if (item.product_image) { %>
                    <div class="w-14 h-14 rounded-xl overflow-hidden bg-zinc-100 shrink-0">
                        <img src="<%= item.product_image %>" class="w-full h-full object-cover" loading="lazy">
                    </div>
                    <% } else { %>
                    <div class="w-14 h-14 rounded-xl bg-zinc-100 shrink-0 flex items-center justify-center">
                        <svg class="w-6 h-6 text-zinc-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/>
                        </svg>
                    </div>
                    <% } %>

                    <!-- Name + weight -->
                    <div class="flex-1 min-w-0">
                        <p class="font-bold text-zinc-800 text-sm truncate"><%= item.product_name %></p>
                        <div class="flex items-center gap-1.5 mt-0.5 flex-wrap">
                            <% if (item.variant_weight) { %>
                            <span class="text-[10px] font-black bg-amber-50 text-amber-700 border border-amber-100 px-1.5 py-0.5 rounded-full"><%= item.variant_weight %></span>
                            <% } %>
                            <span class="text-[10px] font-black bg-blue-50 text-blue-700 border border-blue-100 px-1.5 py-0.5 rounded-full">×<%= item.quantity %></span>
                        </div>
                    </div>

                    <!-- Line total -->
                    <div class="text-right shrink-0">
                        <p class="font-black text-zinc-900 text-sm">Rs. <%= (item.price * item.quantity).toLocaleString('en-IN') %></p>
                        <p class="text-[10px] text-zinc-400 font-medium">@ Rs. <%= Number(item.price).toLocaleString('en-IN') %></p>
                    </div>
                </div>
                <% }) %>
            </div>
            <% } else { %>
            <p class="text-sm text-zinc-400 font-medium text-center py-3">Item details unavailable</p>
            <% } %>

            <div class="flex justify-between items-center mt-4 pt-4 border-t border-zinc-100">
                <span class="text-sm font-black text-zinc-900">Total Paid</span>
                <span class="text-xl font-black text-green-700">Rs. <%= order.total.toLocaleString('en-IN') %></span>
            </div>
        </div>

        <!-- Delivery address -->
        <div class="bg-white rounded-2xl border border-zinc-100 shadow-sm p-6 mb-4">
            <p class="text-xs font-black uppercase tracking-widest text-zinc-400 mb-3">Delivering To</p>
            <p class="font-black text-zinc-800"><%= order.addresses.first_name %> <%= order.addresses.last_name %></p>
            <p class="text-sm text-zinc-500 mt-1 leading-relaxed">
                <%= order.addresses.address %>,<br>
                <%= order.addresses.city %> — <%= order.addresses.pin_code %>
            </p>
            <p class="text-sm text-zinc-500 mt-1"><%= order.addresses.phone %></p>
        </div>

        <!-- Payment method -->
        <div class="bg-white rounded-2xl border border-zinc-100 shadow-sm px-6 py-4 mb-8 flex items-center justify-between">
            <div class="flex items-center gap-3">
                <div class="w-9 h-9 bg-yellow-50 rounded-xl flex items-center justify-center">
                    <svg class="w-5 h-5 text-yellow-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z"/>
                    </svg>
                </div>
                <div>
                    <p class="text-sm font-black text-zinc-800">Cash On Delivery</p>
                    <p class="text-xs text-zinc-400 font-medium">Pay when your order arrives</p>
                </div>
            </div>
            <span class="text-[10px] font-black bg-yellow-100 text-yellow-700 px-2.5 py-1 rounded-full uppercase tracking-widest">COD</span>
        </div>

        <!-- CTA Buttons -->
        <div class="flex flex-col sm:flex-row gap-3">
            <a href="/my-orders"
                class="flex-1 text-center bg-zinc-900 hover:bg-green-700 text-white font-black py-4 rounded-2xl uppercase tracking-widest text-sm transition-all active:scale-95">
                Track Order
            </a>
            <a href="/"
                class="flex-1 text-center bg-white border border-zinc-200 hover:border-zinc-400 text-zinc-700 font-black py-4 rounded-2xl uppercase tracking-widest text-sm transition-all active:scale-95">
                Continue Shopping
            </a>
        </div>

    </div>

    <%- include("partials/footer") %>
</body>
</html>
