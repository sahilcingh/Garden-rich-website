<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Reset Password | GardenRich</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body class="bg-green-100 font-sans antialiased text-zinc-900">
    <div class="fixed top-0 left-0 w-full h-full overflow-hidden -z-10">
        <div class="absolute top-[-5%] right-[-5%] w-[35%] h-[35%] bg-green-100 rounded-full blur-[100px] opacity-40"></div>
        <div class="absolute bottom-[5%] left-[-5%] w-[30%] h-[30%] bg-green-50 rounded-full blur-[80px] opacity-60"></div>
    </div>

    <div class="min-h-screen flex items-center justify-center py-12 px-4">
        <div class="max-w-md w-full">

            <div class="text-center mb-8">
                <h1 class="text-4xl font-black text-zinc-900 tracking-tighter">
                    Garden<span class="text-green-600">Rich</span>
                </h1>
                <p class="text-zinc-500 font-medium mt-2">Enter your code and choose a new password.</p>
            </div>

            <div class="bg-white/80 backdrop-blur-xl p-10 rounded-[2.5rem] shadow-2xl shadow-green-900/5 border border-white">

                <div class="flex justify-center mb-6">
                    <div class="w-16 h-16 bg-green-50 rounded-2xl flex items-center justify-center">
                        <svg class="w-8 h-8 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
                        </svg>
                    </div>
                </div>

                <h2 class="text-xl font-black text-zinc-900 text-center mb-1">Reset your password</h2>
                <p class="text-sm text-zinc-500 font-medium text-center mb-6">
                    Code was sent to <span class="font-black text-zinc-800"><%= email %></span>
                </p>

                <% if (error) { %>
                <div class="flex items-start gap-3 bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-2xl text-sm font-medium mb-5">
                    <svg class="w-5 h-5 shrink-0 mt-0.5 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/>
                    </svg>
                    <%= error %>
                </div>
                <% } %>

                <form action="/reset-password" method="POST" class="space-y-5">

                    <!-- OTP input -->
                    <div>
                        <label class="block text-xs font-black uppercase tracking-widest text-zinc-400 mb-2 ml-1">Reset Code</label>
                        <input
                            type="text"
                            name="otp"
                            inputmode="numeric"
                            autocomplete="one-time-code"
                            maxlength="6"
                            placeholder="000000"
                            required
                            autofocus
                            id="otpInput"
                            class="w-full bg-zinc-50 border border-zinc-200 px-5 py-4 rounded-2xl outline-none transition-all focus:bg-white focus:border-green-500 focus:ring-4 focus:ring-green-500/10 text-zinc-800 font-black text-2xl tracking-[0.4em] text-center">
                        <p class="text-center text-xs text-zinc-400 font-medium mt-2">
                            Expires in <span id="countdown" class="font-black text-zinc-700">10:00</span>
                        </p>
                    </div>

                    <!-- New password -->
                    <div class="group">
                        <label class="block text-xs font-black uppercase tracking-widest text-zinc-400 mb-2 ml-1">New Password</label>
                        <div class="relative">
                            <input type="password" name="password" id="newPassword" required minlength="6"
                                placeholder="Min. 6 characters"
                                class="w-full bg-zinc-50 border border-zinc-200 px-5 py-4 pr-14 rounded-2xl outline-none transition-all focus:bg-white focus:border-green-500 focus:ring-4 focus:ring-green-500/10 text-zinc-800 font-medium">
                            <button type="button" onclick="togglePass('newPassword', 'eye1', 'eyeoff1')"
                                class="absolute right-5 top-1/2 -translate-y-1/2 text-zinc-300 hover:text-zinc-500 transition-colors">
                                <svg id="eye1" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0zM2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
                                </svg>
                                <svg id="eyeoff1" class="w-5 h-5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.542-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.542 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21"/>
                                </svg>
                            </button>
                        </div>
                    </div>

                    <!-- Confirm password -->
                    <div class="group">
                        <label class="block text-xs font-black uppercase tracking-widest text-zinc-400 mb-2 ml-1">Confirm Password</label>
                        <div class="relative">
                            <input type="password" name="confirmPassword" id="confirmPassword" required minlength="6"
                                placeholder="Re-enter password"
                                class="w-full bg-zinc-50 border border-zinc-200 px-5 py-4 pr-14 rounded-2xl outline-none transition-all focus:bg-white focus:border-green-500 focus:ring-4 focus:ring-green-500/10 text-zinc-800 font-medium">
                            <button type="button" onclick="togglePass('confirmPassword', 'eye2', 'eyeoff2')"
                                class="absolute right-5 top-1/2 -translate-y-1/2 text-zinc-300 hover:text-zinc-500 transition-colors">
                                <svg id="eye2" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0zM2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
                                </svg>
                                <svg id="eyeoff2" class="w-5 h-5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.542-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.542 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21"/>
                                </svg>
                            </button>
                        </div>
                        <!-- Live match indicator -->
                        <p id="matchMsg" class="text-xs font-bold mt-1.5 ml-1 hidden"></p>
                    </div>

                    <button type="submit" id="submitBtn"
                        class="w-full bg-zinc-900 text-white py-4 rounded-2xl font-bold text-base hover:bg-green-700 transition-all shadow-xl shadow-zinc-200 active:scale-[0.98]">
                        Reset Password
                    </button>
                </form>

                <div class="mt-6 pt-5 border-t border-zinc-100 flex items-center justify-between text-sm">
                    <a href="/forgot-password" class="font-bold text-zinc-400 hover:text-zinc-600 transition-colors">← Request new code</a>
                    <a href="/login" class="font-bold text-zinc-400 hover:text-zinc-600 transition-colors">Back to Login</a>
                </div>
            </div>
        </div>
    </div>

    <script>
        // Countdown timer — 10 minutes
        let seconds = 600;
        const el = document.getElementById("countdown");
        const timer = setInterval(() => {
            seconds--;
            const m = Math.floor(seconds / 60).toString().padStart(2, "0");
            const s = (seconds % 60).toString().padStart(2, "0");
            el.textContent = `${m}:${s}`;
            if (seconds <= 60) el.classList.add("text-red-500");
            if (seconds <= 0) {
                clearInterval(timer);
                el.textContent = "Expired";
            }
        }, 1000);

        // Password match indicator
        const pw = document.getElementById("newPassword");
        const cpw = document.getElementById("confirmPassword");
        const msg = document.getElementById("matchMsg");

        function checkMatch() {
            if (!cpw.value) { msg.classList.add("hidden"); return; }
            msg.classList.remove("hidden");
            if (pw.value === cpw.value) {
                msg.textContent = "✓ Passwords match";
                msg.className = "text-xs font-bold mt-1.5 ml-1 text-green-600";
            } else {
                msg.textContent = "✗ Passwords do not match";
                msg.className = "text-xs font-bold mt-1.5 ml-1 text-red-500";
            }
        }

        pw.addEventListener("input", checkMatch);
        cpw.addEventListener("input", checkMatch);

        // Toggle password visibility
        function togglePass(inputId, eyeId, eyeOffId) {
            const input = document.getElementById(inputId);
            const eye = document.getElementById(eyeId);
            const eyeOff = document.getElementById(eyeOffId);
            if (input.type === "password") {
                input.type = "text";
                eye.classList.add("hidden");
                eyeOff.classList.remove("hidden");
            } else {
                input.type = "password";
                eye.classList.remove("hidden");
                eyeOff.classList.add("hidden");
            }
        }
    </script>
</body>
</html>
