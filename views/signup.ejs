<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sign Up | GardenRich</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body class="bg-green-100 font-sans antialiased text-zinc-900">
    <div class="fixed top-0 left-0 w-full h-full overflow-hidden -z-10">
        <div class="absolute top-[-5%] right-[-5%] w-[35%] h-[35%] bg-green-100 rounded-full blur-[100px] opacity-40"></div>
        <div class="absolute bottom-[5%] left-[-5%] w-[30%] h-[30%] bg-green-50 rounded-full blur-[80px] opacity-60"></div>
    </div>

    <div class="min-h-screen flex items-center justify-center py-12 px-4">
        <div class="max-w-md w-full">
            
            <div class="text-center mb-8">
                <h1 class="text-4xl font-black text-zinc-900 tracking-tighter">
                    Garden<span class="text-green-600">Rich</span>
                </h1>
                <p class="text-zinc-500 font-medium mt-2">Join our community of plant lovers.</p>
            </div>

            <div class="bg-white/80 backdrop-blur-xl p-10 rounded-[2.5rem] shadow-2xl shadow-green-900/5 border border-white">
                <form id="signupForm" action="/signup" method="POST" class="space-y-5" onsubmit="handleSubmit(event)">

                    <% if (error) { %>
                    <div class="flex items-start gap-3 bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-2xl text-sm font-medium">
                        <svg class="w-5 h-5 shrink-0 mt-0.5 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/>
                        </svg>
                        <%= error %>
                    </div>
                    <% } %>

                    <div class="group">
                        <label class="block text-xs font-black uppercase tracking-widest text-zinc-400 mb-2 ml-1">Full Name</label>
                        <div class="relative">
                            <input type="text" name="name" required placeholder="John Doe" 
                                class="w-full bg-zinc-50 border border-zinc-200 px-5 py-4 rounded-2xl outline-none transition-all focus:bg-white focus:border-green-500 focus:ring-4 focus:ring-green-500/10 text-zinc-800 font-medium">
                            <div class="absolute right-5 top-1/2 -translate-y-1/2 text-zinc-300 group-focus-within:text-green-500 transition-colors">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                                </svg>
                            </div>
                        </div>
                    </div>

                    <div class="group">
                        <label class="block text-xs font-black uppercase tracking-widest text-zinc-400 mb-2 ml-1">Email Address</label>
                        <div class="relative">
                            <input type="email" name="email" required placeholder="name@gmail.com" 
                                class="w-full bg-zinc-50 border border-zinc-200 px-5 py-4 rounded-2xl outline-none transition-all focus:bg-white focus:border-green-500 focus:ring-4 focus:ring-green-500/10 text-zinc-800 font-medium">
                            <div class="absolute right-5 top-1/2 -translate-y-1/2 text-zinc-300 group-focus-within:text-green-500 transition-colors">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                                </svg>
                            </div>
                        </div>
                    </div>

                    <div class="group">
                        <label class="block text-xs font-black uppercase tracking-widest text-zinc-400 mb-2 ml-1">Mobile Number</label>
                        <div class="relative">
                            <input type="tel" name="mobile" required placeholder="10-digit mobile number"
                                pattern="[0-9]{10}" maxlength="10"
                                class="w-full bg-zinc-50 border border-zinc-200 px-5 py-4 rounded-2xl outline-none transition-all focus:bg-white focus:border-green-500 focus:ring-4 focus:ring-green-500/10 text-zinc-800 font-medium">
                            <div class="absolute right-5 top-1/2 -translate-y-1/2 text-zinc-300 group-focus-within:text-green-500 transition-colors">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z" />
                                </svg>
                            </div>
                        </div>
                    </div>

                    <div class="group">
                        <label class="block text-xs font-black uppercase tracking-widest text-zinc-400 mb-2 ml-1">Create Password</label>
                        <div class="relative">
                            <input type="password" name="password" id="passwordInput" required minlength="6" placeholder="Min. 6 characters" 
                                class="w-full bg-zinc-50 border border-zinc-200 px-5 py-4 pr-14 rounded-2xl outline-none transition-all focus:bg-white focus:border-green-500 focus:ring-4 focus:ring-green-500/10 text-zinc-800 font-medium">
                            <button type="button" onclick="togglePassword()"
                                class="absolute right-5 top-1/2 -translate-y-1/2 text-zinc-300 hover:text-zinc-500 transition-colors">
                                <svg id="eyeIcon" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0zM2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
                                </svg>
                                <svg id="eyeOffIcon" class="w-5 h-5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.542-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.542 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21"/>
                                </svg>
                            </button>
                        </div>
                    </div>

                    <button type="submit" id="submitBtn"
                        class="w-full bg-zinc-900 text-white py-5 mt-4 rounded-2xl font-bold text-lg hover:bg-green-700 transition-all shadow-xl shadow-zinc-200 active:scale-[0.98] flex items-center justify-center gap-3">
                        <span id="btnText">Create Account</span>
                        <svg id="btnSpinner" class="hidden w-5 h-5 animate-spin" fill="none" viewBox="0 0 24 24">
                            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8z"></path>
                        </svg>
                    </button>
                </form>

                <div class="relative flex items-center py-4">
                    <div class="flex-grow border-t border-zinc-100"></div>
                </div>
                <p class="text-center text-sm font-medium text-zinc-500">
                    Already part of GardenRich? 
                    <a href="/login" class="font-black text-green-700 hover:text-green-800 transition-colors">Log in</a>
                </p>
            </div>
        </div>
    </div>

    <script>
        let submitted = false;

        function handleSubmit(e) {
            if (submitted) {
                e.preventDefault();
                return;
            }
            submitted = true;

            const btn = document.getElementById('submitBtn');
            const text = document.getElementById('btnText');
            const spinner = document.getElementById('btnSpinner');

            btn.disabled = true;
            btn.classList.remove('hover:bg-green-700', 'active:scale-[0.98]');
            btn.classList.add('opacity-70', 'cursor-not-allowed');
            text.textContent = 'Sending code…';
            spinner.classList.remove('hidden');
        }

        function togglePassword() {
            const input = document.getElementById('passwordInput');
            const eye = document.getElementById('eyeIcon');
            const eyeOff = document.getElementById('eyeOffIcon');
            if (input.type === 'password') {
                input.type = 'text';
                eye.classList.add('hidden');
                eyeOff.classList.remove('hidden');
            } else {
                input.type = 'password';
                eye.classList.remove('hidden');
                eyeOff.classList.add('hidden');
            }
        }
    </script>
</body>
</html>
