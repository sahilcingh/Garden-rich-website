<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Profile | GardenRich</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body class="bg-zinc-50 text-zinc-900">
    <%- include("partials/header") %>

    <main class="max-w-3xl mx-auto py-20 px-6">
        <div class="bg-white rounded-[2.5rem] border border-zinc-100 shadow-xl overflow-hidden">
            <div class="bg-green-600 p-8 text-white">
                <h1 class="text-3xl font-black tracking-tight">Account Settings</h1>
                <p class="text-green-100 font-medium">Manage your personal information</p>
            </div>

            <form action="/profile/update" method="POST" class="p-8 space-y-6">
                <div>
                    <label class="block text-xs font-black text-zinc-400 uppercase tracking-widest mb-2">Email Address</label>
                    <input type="email" value="<%= profile.email %>" disabled 
                        class="w-full px-4 py-3 bg-zinc-50 border border-zinc-200 rounded-xl text-zinc-400 cursor-not-allowed">
                    <p class="text-[10px] text-zinc-400 mt-1 italic font-medium">Email cannot be changed for security reasons.</p>
                </div>

                <div>
                    <label class="block text-xs font-black text-zinc-900 uppercase tracking-widest mb-2">Full Name</label>
                    <input type="text" name="name" value="<%= profile.name %>" required
                        class="w-full px-4 py-3 border border-zinc-200 rounded-xl focus:outline-none focus:ring-4 focus:ring-green-500/10 focus:border-green-500 transition-all font-bold">
                </div>

                <div>
                    <label class="block text-xs font-black text-zinc-900 uppercase tracking-widest mb-2">Mobile Number</label>
                    <input type="text" name="mobile" value="<%= profile.mobile %>" required
                        class="w-full px-4 py-3 border border-zinc-200 rounded-xl focus:outline-none focus:ring-4 focus:ring-green-500/10 focus:border-green-500 transition-all font-bold">
                </div>

                <div class="pt-4 flex gap-4">
                    <button type="submit" 
                        class="bg-zinc-900 text-white px-8 py-3 rounded-xl font-black hover:bg-green-700 transition-all shadow-lg active:scale-95">
                        SAVE CHANGES
                    </button>
                    <a href="/" class="px-8 py-3 rounded-xl font-bold text-zinc-400 hover:text-zinc-900 transition-colors flex items-center">
                        Cancel
                    </a>
                </div>
            </form>
        </div>
    </main>
</body>
</html>
