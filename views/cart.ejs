<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Your Cart | GardenRich</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>

<body class="bg-zinc-50 font-sans antialiased text-zinc-900">
    <%- include("partials/header") %>

    <%
        const _baseShipping = parseFloat(shippingCost || 0);
        const _freeAbove    = parseFloat(freeAbove || 0);
        const _minOrder     = parseFloat(minOrder || 0);
        const _subtotal     = parseFloat(total || 0);
        const _shippingCost = (_freeAbove > 0 && _subtotal >= _freeAbove) ? 0 : _baseShipping;
        const _finalTotal   = _subtotal + _shippingCost;
        const _isFreeShipping  = _shippingCost === 0;
        const _freeShippingGap = (_freeAbove > 0 && _subtotal < _freeAbove) ? (_freeAbove - _subtotal) : 0;
        const _progressPct     = _freeAbove > 0 ? Math.min(100, (_subtotal / _freeAbove) * 100).toFixed(1) : 0;
        // Discount hint values passed from server
        const _discountCode     = discountCode || "";
        const _discountType     = discountType || "none";
        const _discountValue    = parseFloat(discountValue || 0);
        const _discountMinOrder = parseFloat(discountMinOrder || 0);
        const _hasActiveDiscount = _discountCode && _discountType !== "none";
    %>

    <%# Hidden data anchor — JS reads all thresholds from here %>
    <span id="shippingCostValue"
        data-shipping="<%= _shippingCost %>"
        data-base-shipping="<%= _baseShipping %>"
        data-free-above="<%= _freeAbove %>"
        data-min-order="<%= _minOrder %>"
        class="hidden"></span>

    <div class="max-w-7xl mx-auto px-6 py-10 pb-24">

        <a href="/" class="inline-flex items-center text-sm font-bold text-green-700 hover:text-green-800 mb-6 group transition-colors">
            <svg class="w-4 h-4 mr-2 transform group-hover:-translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
            </svg>
            Continue Shopping
        </a>

        <h1 id="cartHeading" class="text-3xl font-black mb-8 text-zinc-900 tracking-tight">
            Your Cart
            <span id="cartItemCount" class="text-zinc-400 text-xl font-normal ml-2">(<%= cartItems.length %> Items)</span>
        </h1>

        <% if (cartItems.length > 0) { %>

        <% if (_freeAbove > 0) { %>
        <div id="freeShippingProgress"
             class="mb-5 bg-white rounded-2xl border border-zinc-100 px-5 py-4 <%= _freeShippingGap === 0 ? 'hidden' : '' %>">
            <div class="flex justify-between items-center mb-2">
                <p class="text-xs font-black text-zinc-600">
                    Add <span id="freeShippingAmount" class="text-green-600">Rs. <%= _freeShippingGap.toLocaleString('en-IN') %></span> more for FREE shipping!
                </p>
                <p id="freeShippingCounter" class="text-xs text-zinc-400 font-bold">
                    Rs. <%= _subtotal.toLocaleString('en-IN') %> / Rs. <%= _freeAbove.toLocaleString('en-IN') %>
                </p>
            </div>
            <div class="w-full bg-zinc-100 rounded-full h-2">
                <div id="freeShippingBar" class="bg-green-500 h-2 rounded-full transition-all duration-300"
                     style="width: <%= _progressPct %>%"></div>
            </div>
        </div>

        <div id="freeShippingUnlocked"
             class="mb-5 bg-green-50 border border-green-200 rounded-2xl px-5 py-3 flex items-center gap-2 <%= _freeShippingGap === 0 ? '' : 'hidden' %>">
            <svg class="w-5 h-5 text-green-600 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
            </svg>
            <p class="text-sm font-black text-green-700">🎉 You've unlocked FREE shipping!</p>
        </div>
        <% } %>

        <div id="minOrderWarning"
             class="mb-5 bg-orange-50 border border-orange-200 rounded-2xl px-5 py-3 flex items-center gap-2
                    <%= (_minOrder > 0 && _subtotal < _minOrder) ? '' : 'hidden' %>">
            <svg class="w-5 h-5 text-orange-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/>
            </svg>
            <p class="text-sm font-bold text-orange-700">
                Minimum order value is <strong>Rs. <%= _minOrder.toLocaleString('en-IN') %></strong>. Add more items to checkout.
            </p>
        </div>

        <div id="cartPageContainer" class="flex flex-col lg:flex-row gap-8">

            <!-- Cart Items -->
            <div id="cartItemsList" class="lg:w-2/3 space-y-3">
                <% cartItems.forEach(item => { %>
                <div class="cart-item flex items-center gap-4 p-4 bg-white rounded-2xl shadow-sm border border-zinc-100 hover:shadow-md transition-all"
                    data-id="<%= item.product_id %>"
                    data-variant-id="<%= item.variant_id %>"
                    data-price="<%= item.price %>"
                    data-stock="<%= item.stock || 99 %>">

                    <div class="w-20 h-20 bg-zinc-100 rounded-xl overflow-hidden shrink-0">
                        <img src="<%= item.product_image %>" class="w-full h-full object-cover" alt="<%= item.product_name %>">
                    </div>

                    <div class="flex-1 min-w-0">
                        <% if (item.product_brand) { %>
                        <p class="text-[10px] font-black uppercase tracking-widest text-zinc-400 mb-0.5"><%= item.product_brand %></p>
                        <% } %>
                        <h3 class="font-bold text-zinc-800 text-sm leading-tight"><%= item.product_name %></h3>
                        <p class="text-xs text-zinc-400 font-medium mt-0.5"><%= item.weight %></p>
                        <div class="flex items-center gap-2 mt-1.5 flex-wrap">
                            <p class="font-black text-green-700 text-sm">Rs. <%= item.price %></p>
                            <% if (item.mrp && item.mrp > item.price) { %>
                            <p class="text-xs text-zinc-400 line-through font-medium">Rs. <%= item.mrp %></p>
                            <span class="text-[10px] font-black text-green-600 bg-green-50 px-1.5 py-0.5 rounded-md">
                                <%= Math.round((item.mrp - item.price) / item.mrp * 100) %>% OFF
                            </span>
                            <% } %>
                        </div>
                        <% if (item.stock <= 3 && item.stock > 0) { %>
                        <p class="text-[10px] font-black text-orange-500 mt-1">⚠ Only <%= item.stock %> left!</p>
                        <% } else if (item.stock === 0) { %>
                        <p class="text-[10px] font-black text-red-500 mt-1">Out of stock</p>
                        <% } %>
                    </div>

                    <div class="hidden sm:block text-right shrink-0 mr-2">
                        <p class="text-[10px] font-black uppercase tracking-widest text-zinc-400">Subtotal</p>
                        <p class="item-subtotal font-black text-zinc-900 text-sm mt-0.5">
                            Rs. <%= (item.price * item.quantity).toLocaleString('en-IN') %>
                        </p>
                    </div>

                    <% if (item.stock === 0) { %>
                    <!-- OOS: one-tap remove button -->
                    <button onclick="removeOOSItem(this)"
                        class="flex items-center gap-1.5 px-3 py-2.5 bg-red-50 hover:bg-red-100 border border-red-200 text-red-500 hover:text-red-600 rounded-xl text-xs font-black transition-all active:scale-95 shrink-0">
                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                        </svg>
                        Remove
                    </button>
                    <% } else { %>
                    <div class="flex items-center bg-zinc-900 text-white rounded-xl overflow-hidden shrink-0 shadow-md">
                        <button onclick="updateCartQty(this, -1)"
                            class="px-3 py-2.5 hover:bg-zinc-700 text-sm font-bold transition-colors leading-none select-none">−</button>
                        <span class="qty-text px-2 py-2.5 font-bold text-xs w-8 text-center leading-none select-none"><%= item.quantity %></span>
                        <button onclick="updateCartQty(this, 1)"
                            class="px-3 py-2.5 hover:bg-zinc-700 text-sm font-bold transition-colors leading-none select-none">+</button>
                    </div>
                    <% } %>

                </div>
                <% }) %>
            </div>

            <!-- Order Summary -->
            <div id="orderSummaryPanel" class="lg:w-1/3">
                <div class="bg-white p-6 rounded-2xl shadow-lg border border-zinc-100 sticky top-24">
                    <h2 class="text-lg font-black text-zinc-900 mb-5 pb-4 border-b border-zinc-100">Order Summary</h2>

                    <!-- Item Breakdown -->
                    <div class="space-y-2 mb-4" id="summaryItemsList">
                        <% cartItems.forEach(item => { %>
                        <div class="flex justify-between text-sm" id="summary-row-<%= item.variant_id %>">
                            <span class="text-zinc-500 font-medium truncate mr-2">
                                <%= item.product_name %> <span class="text-zinc-400 text-xs">(<%= item.weight %>)</span>
                                <span class="summary-item-qty text-zinc-400 font-bold">×<%= item.quantity %></span>
                            </span>
                            <span class="summary-item-total font-bold text-zinc-700 shrink-0" data-id="<%= item.variant_id %>">
                                Rs. <%= (item.price * item.quantity).toLocaleString('en-IN') %>
                            </span>
                        </div>
                        <% }) %>
                    </div>

                    <!-- Totals -->
                    <div class="space-y-3 text-sm border-t border-zinc-100 pt-4">
                        <div class="flex justify-between text-zinc-600">
                            <span>Subtotal</span>
                            <span id="summaryOrderTotal" class="font-bold">Rs. <%= _subtotal.toLocaleString('en-IN') %></span>
                        </div>

                        <!-- Discount row — hidden until code applied -->
                        <div id="discountRow" class="hidden justify-between text-green-600">
                            <span class="font-medium">Discount</span>
                            <span id="discountAmount" class="font-black">-Rs. 0</span>
                        </div>

                        <div class="flex justify-between text-zinc-600">
                            <span>Shipping</span>
                            <span id="shippingDisplay" class="font-black <%= _isFreeShipping ? 'text-green-600' : 'text-zinc-900' %>">
                                <% if (_isFreeShipping) { %>FREE<% } else { %>Rs. <%= _shippingCost.toLocaleString('en-IN') %><% } %>
                            </span>
                        </div>

                        <div class="flex justify-between text-zinc-600">
                            <span>Taxes</span>
                            <span class="font-bold">Included</span>
                        </div>
                    </div>

                    <div class="mt-5 pt-4 border-t border-zinc-100">
                        <div class="flex justify-between items-center mb-1">
                            <span class="text-base font-black text-zinc-900">Total Amount</span>
                            <span id="summaryFinalTotal" class="text-2xl font-black text-zinc-900">
                                Rs. <%= _finalTotal.toLocaleString('en-IN') %>
                            </span>
                        </div>
                        <p class="text-right text-xs text-zinc-400">Inclusive of all taxes</p>
                    </div>

                    <!-- Promo Code -->
                    <div class="mt-4 pt-4 border-t border-zinc-100">
                        <p class="text-xs font-black uppercase tracking-widest text-zinc-400 mb-2">Promo Code</p>

                        <%# Active discount hint — shown below input so user knows the code %>
                        <% if (_hasActiveDiscount) { %>
                        <div class="mb-2 px-3 py-2 bg-green-50 border border-green-200 rounded-xl flex items-center gap-2">
                            <svg class="w-3.5 h-3.5 text-green-600 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-5 5a2 2 0 01-2.828 0l-7-7A2 2 0 013 9.172V5a2 2 0 012-2z"/>
                            </svg>
                            <p class="text-[11px] font-bold text-green-700">
                                Use code <button onclick="document.getElementById('discountCodeInput').value='<%= _discountCode %>'" class="font-black text-green-800 bg-green-100 px-1.5 py-0.5 rounded-md hover:bg-green-200 transition-colors"><%= _discountCode %></button>
                                for <span class="font-black"><%= _discountType === 'percentage' ? _discountValue + '% off' : 'Rs. ' + _discountValue + ' off' %></span>
                                <% if (_discountMinOrder > 0) { %><span class="text-green-600"> on orders above Rs. <%= _discountMinOrder %></span><% } %>
                            </p>
                        </div>
                        <% } %>

                        <div id="discountInputRow" class="flex gap-2">
                            <input type="text" id="discountCodeInput" placeholder="Enter code"
                                class="flex-1 bg-zinc-50 border border-zinc-200 p-2.5 rounded-xl text-sm font-bold uppercase focus:outline-none focus:border-green-500 transition-all tracking-widest"
                                oninput="this.value = this.value.toUpperCase()">
                            <button onclick="applyDiscount()"
                                class="px-4 py-2.5 bg-zinc-900 hover:bg-green-700 text-white text-xs font-black rounded-xl transition-all active:scale-95">
                                Apply
                            </button>
                        </div>
                        <div id="discountMsg" class="mt-2 text-xs font-bold hidden"></div>

                        <div id="discountApplied" class="hidden items-center justify-between bg-green-50 border border-green-200 rounded-xl px-3 py-2.5 mt-2">
                            <div>
                                <p class="text-xs font-black text-green-700">Discount Applied! 🎉</p>
                                <p class="text-[10px] text-green-600 mt-0.5" id="discountAppliedLabel"></p>
                            </div>
                            <button onclick="removeDiscount()" class="text-zinc-400 hover:text-red-400 transition-colors ml-3">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                                </svg>
                            </button>
                        </div>
                    </div>

                    <%
                        const _hasOOS = cartItems.some(item => item.stock === 0);
                        const _checkoutBlocked = (_minOrder > 0 && _subtotal < _minOrder) || _hasOOS;
                        const _checkoutLabel = _hasOOS
                            ? 'Remove Out-of-Stock Items'
                            : (_minOrder > 0 && _subtotal < _minOrder)
                                ? 'Min. Order Rs. ' + _minOrder.toLocaleString('en-IN')
                                : 'Proceed to Checkout';
                    %>
                    <% if (_hasOOS) { %>
                    <div class="mt-4 mb-2 bg-red-50 border border-red-200 rounded-xl px-4 py-3 flex items-start gap-2">
                        <svg class="w-4 h-4 text-red-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/>
                        </svg>
                        <p class="text-xs font-bold text-red-600">Some items are out of stock. Remove them to proceed.</p>
                    </div>
                    <% } %>
                    <button id="checkoutBtn" onclick="proceedToCheckout()"
                        class="w-full py-4 rounded-xl font-black mt-2 uppercase tracking-widest text-sm transition-all
                            <%= _checkoutBlocked
                                ? 'bg-zinc-300 text-zinc-500 cursor-not-allowed'
                                : 'bg-green-700 hover:bg-green-800 text-white shadow-lg shadow-green-100 active:scale-95' %>"
                        <%= _checkoutBlocked ? 'disabled' : '' %>>
                        <%= _checkoutLabel %>
                    </button>

                    <!-- Trust Badges -->
                    <div class="mt-5 pt-4 border-t border-zinc-100 flex items-center justify-center gap-4 text-xs text-zinc-400 font-medium">
                        <span class="flex items-center gap-1">
                            <svg class="w-3.5 h-3.5 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
                            </svg>
                            Secure
                        </span>
                        <span class="flex items-center gap-1">
                            <svg class="w-3.5 h-3.5 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4"/>
                            </svg>
                            Fast Delivery
                        </span>
                        <span class="flex items-center gap-1">
                            <svg class="w-3.5 h-3.5 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1"/>
                            </svg>
                            COD
                        </span>
                    </div>
                </div>
            </div>
        </div>

        <% } else { %>

        <div id="cartPageContainer" class="flex flex-col items-center justify-center py-24 bg-white rounded-3xl border border-dashed border-zinc-200 text-center">
            <div class="inline-flex items-center justify-center w-24 h-24 bg-zinc-100 rounded-full mb-6">
                <svg class="w-12 h-12 text-zinc-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/>
                </svg>
            </div>
            <h2 class="text-2xl font-black text-zinc-900 mb-2">Your cart is empty</h2>
            <p class="text-zinc-400 font-medium mb-8 max-w-xs">Looks like you haven't added anything yet. Start shopping!</p>
            <a href="/" class="inline-block bg-green-600 hover:bg-green-700 text-white font-black py-4 px-10 rounded-2xl transition-all active:scale-95 uppercase tracking-widest text-sm shadow-lg shadow-green-100">
                Browse Products
            </a>
        </div>

        <% } %>

    </div>

    <%- include("partials/footer") %>
</body>
</html>
