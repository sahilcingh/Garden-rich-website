<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>GardenRich</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>

<body>
    <nav class="sticky top-0 z-50 w-full bg-white/80 backdrop-blur-md border-b border-zinc-100 shadow-sm">
        <div class="max-w-7xl mx-auto px-6 py-3 flex items-center justify-between">

            <a href="/" class="flex items-center space-x-3 group">
                <h1 class="text-2xl font-black text-zinc-900 tracking-tighter">
                    Garden<span class="text-green-600">Rich</span>
                </h1>
            </a>

            <% if (!user || user.role !== 'ADMIN') { %>
            <form action="/" method="GET" class="hidden md:flex flex-1 mx-12 max-w-2xl">
                <div class="relative w-full group">
                    <input type="text" name="search" placeholder="Search for fresh products..."
                        class="w-full pl-12 pr-4 py-2.5 bg-zinc-50 border border-zinc-200 rounded-2xl focus:outline-none focus:ring-4 focus:ring-green-500/10 focus:border-green-500 transition-all text-sm"
                        value="<%= typeof query !== 'undefined' ? query : '' %>">
                    <button type="submit"
                        class="absolute left-4 top-1/2 -translate-y-1/2 text-zinc-400 group-focus-within:text-green-600 transition-colors">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                        </svg>
                    </button>
                </div>
            </form>
            <% } %>

            <div class="flex items-center space-x-4">

                <% if (user) { %>

                <!-- Admin Notification Bell -->
                <% if (user.role === 'ADMIN') { %>
                <div class="relative" id="notifWrapper">
                    <button id="notifBtn" onclick="toggleNotifPanel(event)"
                        class="relative p-2 rounded-full hover:bg-zinc-100 transition-all text-zinc-600 hover:text-zinc-900">
                        <svg id="notifBell" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/>
                        </svg>
                        <span id="notifBadge"
                            style="top:0;right:0;transform:translate(30%,-30%);"
                            class="hidden absolute bg-red-500 text-white text-[9px] font-black min-w-[18px] h-[18px] flex items-center justify-center rounded-full ring-2 ring-white px-1 leading-none">
                            0
                        </span>
                    </button>

                    <!-- Notification Panel -->
                    <div id="notifPanel"
                        class="hidden absolute right-0 mt-3 w-80 bg-white border border-zinc-100 rounded-2xl shadow-2xl z-50 overflow-hidden ring-1 ring-black/5">

                        <!-- Header -->
                        <div class="flex items-center justify-between px-4 py-3 border-b border-zinc-100 bg-zinc-50">
                            <div>
                                <p class="text-xs font-black uppercase tracking-widest text-zinc-700">Notifications</p>
                                <p id="notifSubtitle" class="text-[10px] text-zinc-400 font-medium mt-0.5">New orders will appear here</p>
                            </div>
                            <button onclick="_clearNotifications()"
                                class="text-[10px] font-black text-red-400 hover:text-red-600 transition-colors uppercase tracking-widest">
                                Clear All
                            </button>
                        </div>

                        <!-- List -->
                        <div id="notifList" class="max-h-80 overflow-y-auto">
                            <div id="notifEmpty" class="flex flex-col items-center justify-center py-10 text-center px-4">
                                <div class="w-12 h-12 bg-zinc-100 rounded-full flex items-center justify-center mb-3">
                                    <svg class="w-6 h-6 text-zinc-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                                            d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/>
                                    </svg>
                                </div>
                                <p class="text-xs font-black text-zinc-500">All caught up!</p>
                                <p class="text-[10px] text-zinc-400 mt-1">No new orders right now</p>
                            </div>
                        </div>

                        <!-- Footer -->
                        <div class="px-4 py-3 border-t border-zinc-100 bg-zinc-50 flex items-center justify-between">
                            <p id="notifFooterCount" class="text-[10px] text-zinc-400 font-bold"></p>
                            <a href="/admin/orders"
                                class="text-xs font-black text-green-700 hover:text-green-800 transition-colors uppercase tracking-widest">
                                View All Orders →
                            </a>
                        </div>
                    </div>
                </div>
                <% } %>

                <div class="relative">
                    <button id="userButton" onclick="toggleUserMenu(event)"
                        class="flex items-center space-x-3 text-zinc-700 hover:bg-zinc-50 p-1.5 pr-4 rounded-full border border-zinc-100 transition-all hover:shadow-md active:scale-95">
                        <div class="w-8 h-8 rounded-full <%= user.role === 'ADMIN' ? 'bg-zinc-900' : 'bg-green-600' %> text-white flex items-center justify-center font-bold text-sm shadow-sm ring-2 ring-white">
                            <%= user.name.charAt(0).toUpperCase() %>
                        </div>
                        <span class="font-bold text-sm tracking-tight text-zinc-800"><%= user.name %></span>
                        <% if (user.role === 'ADMIN') { %>
                        <span class="text-[9px] font-black uppercase tracking-widest bg-zinc-900 text-white px-2 py-0.5 rounded-full">Admin</span>
                        <% } %>
                        <svg class="w-4 h-4 text-zinc-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                        </svg>
                    </button>

                    <div id="userMenu"
                        class="hidden absolute right-0 mt-4 w-56 bg-white border border-zinc-100 rounded-2xl shadow-2xl z-50 py-2 ring-1 ring-black/5">
                        <div class="px-4 py-2 mb-2 border-b border-zinc-50">
                            <p class="text-[10px] font-bold text-zinc-400 uppercase tracking-widest">
                                <%= user.role === 'ADMIN' ? 'Admin Panel' : 'Account' %>
                            </p>
                        </div>

                        <% if (user.role === 'ADMIN') { %>
                        <a href="/admin/dashboard"
                            class="flex items-center px-4 py-2.5 mx-2 text-sm text-zinc-700 font-semibold rounded-xl hover:bg-zinc-50 hover:text-green-700 transition-colors group">
                            <svg class="w-5 h-5 mr-3 text-zinc-400 group-hover:text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                    d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"/>
                            </svg>
                            Dashboard
                        </a>
                        <a href="/admin/orders"
                            class="flex items-center px-4 py-2.5 mx-2 text-sm text-zinc-700 font-semibold rounded-xl hover:bg-zinc-50 hover:text-green-700 transition-colors group">
                            <svg class="w-5 h-5 mr-3 text-zinc-400 group-hover:text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                    d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
                            </svg>
                            Manage Orders
                        </a>
                        <% } else { %>
                        <a href="/profile"
                            class="flex items-center px-4 py-2.5 mx-2 text-sm text-zinc-700 font-semibold rounded-xl hover:bg-zinc-50 hover:text-green-700 transition-colors group">
                            <svg class="w-5 h-5 mr-3 text-zinc-400 group-hover:text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                    d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                            </svg>
                            Profile
                        </a>
                        <a href="/my-orders"
                            class="flex items-center px-4 py-2.5 mx-2 text-sm text-zinc-700 font-semibold rounded-xl hover:bg-zinc-50 hover:text-green-700 transition-colors group">
                            <svg class="w-5 h-5 mr-3 text-zinc-400 group-hover:text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                    d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
                            </svg>
                            My Orders
                        </a>
                        <% } %>

                        <div class="mt-2 pt-2 border-t border-zinc-50">
                            <a href="/logout"
                                class="flex items-center px-4 py-2.5 mx-2 text-sm text-red-500 font-bold rounded-xl hover:bg-red-50 transition-colors">
                                <svg class="w-5 h-5 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                        d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
                                </svg>
                                Log Out
                            </a>
                        </div>
                    </div>
                </div>

                <% } else { %>
                <a href="/login"
                    class="flex items-center px-4 py-2.5 text-sm text-zinc-700 font-semibold rounded-xl hover:bg-zinc-50 hover:text-green-700 transition-colors">
                    <svg class="w-5 h-5 mr-2 text-zinc-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                    </svg>
                    Login
                </a>
                <% } %>

                <% if (!user || user.role !== 'ADMIN') { %>
                <a href="/cart" class="relative p-2 mr-2 text-zinc-700 hover:bg-zinc-50 rounded-full transition-all group">
                    <svg class="w-6 h-6 group-hover:text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
                    </svg>
                    <span id="cartCount"
                        class="absolute top-1 right-1 bg-green-600 text-white text-[10px] font-black w-4 h-4 flex items-center justify-center rounded-full ring-2 ring-white <%= cartCount > 0 ? '' : 'hidden' %>">
                        <%= cartCount %>
                    </span>
                </a>
                <% } %>

            </div>
        </div>
    </nav>

    <script src="/javascript/index.js"></script>
</body>
</html>
