<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Forgot Password | GardenRich</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body class="bg-green-100 font-sans antialiased text-zinc-900">
    <div class="fixed top-0 left-0 w-full h-full overflow-hidden -z-10">
        <div class="absolute top-[-5%] right-[-5%] w-[35%] h-[35%] bg-green-100 rounded-full blur-[100px] opacity-40"></div>
        <div class="absolute bottom-[5%] left-[-5%] w-[30%] h-[30%] bg-green-50 rounded-full blur-[80px] opacity-60"></div>
    </div>

    <div class="min-h-screen flex items-center justify-center py-12 px-4">
        <div class="max-w-md w-full">

            <div class="text-center mb-8">
                <h1 class="text-4xl font-black text-zinc-900 tracking-tighter">
                    Garden<span class="text-green-600">Rich</span>
                </h1>
                <p class="text-zinc-500 font-medium mt-2">We'll send a reset code to your email.</p>
            </div>

            <div class="bg-white/80 backdrop-blur-xl p-10 rounded-[2.5rem] shadow-2xl shadow-green-900/5 border border-white">

                <div class="flex justify-center mb-6">
                    <div class="w-16 h-16 bg-green-50 rounded-2xl flex items-center justify-center">
                        <svg class="w-8 h-8 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
                        </svg>
                    </div>
                </div>

                <h2 class="text-xl font-black text-zinc-900 text-center mb-1">Forgot your password?</h2>
                <p class="text-sm text-zinc-500 font-medium text-center mb-6">Enter your email and we'll send you a 6-digit reset code.</p>

                <% if (error) { %>
                <div class="flex items-start gap-3 bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-2xl text-sm font-medium mb-5">
                    <svg class="w-5 h-5 shrink-0 mt-0.5 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/>
                    </svg>
                    <%= error %>
                </div>
                <% } %>

                <% if (success) { %>
                <div class="flex items-start gap-3 bg-green-50 border border-green-200 text-green-700 px-4 py-3 rounded-2xl text-sm font-medium mb-5">
                    <svg class="w-5 h-5 shrink-0 mt-0.5 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                    </svg>
                    <div>
                        <%= success %>
                        <a href="/reset-password<%= typeof resetToken !== 'undefined' ? '?token=' + resetToken : '' %>" class="block mt-2 font-black underline hover:text-green-800">Enter reset code →</a>
                    </div>
                </div>
                <% } else { %>
                <form action="/forgot-password" method="POST" class="space-y-5">
                    <div class="group">
                        <label class="block text-xs font-black uppercase tracking-widest text-zinc-400 mb-2 ml-1">Email Address</label>
                        <div class="relative">
                            <input type="email" name="email" required placeholder="name@gmail.com"
                                class="w-full bg-zinc-50 border border-zinc-200 px-5 py-4 rounded-2xl outline-none transition-all focus:bg-white focus:border-green-500 focus:ring-4 focus:ring-green-500/10 text-zinc-800 font-medium">
                            <div class="absolute right-5 top-1/2 -translate-y-1/2 text-zinc-300 group-focus-within:text-green-500 transition-colors">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                                </svg>
                            </div>
                        </div>
                    </div>

                    <button type="submit"
                        class="w-full bg-zinc-900 text-white py-4 rounded-2xl font-bold text-base hover:bg-green-700 transition-all shadow-xl shadow-zinc-200 active:scale-[0.98]">
                        Send Reset Code
                    </button>
                </form>
                <% } %>

                <div class="mt-6 pt-5 border-t border-zinc-100 text-center">
                    <a href="/login" class="text-sm font-bold text-zinc-400 hover:text-zinc-700 transition-colors">← Back to Login</a>
                </div>
            </div>
        </div>
    </div>
</body>
</html>
