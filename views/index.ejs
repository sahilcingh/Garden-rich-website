<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>GardenRich</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>

<!-- Delete Confirmation Modal -->
<div id="deleteModal" class="fixed inset-0 bg-black/50 backdrop-blur-sm z-50 hidden items-center justify-center p-4">
    <div class="bg-white rounded-3xl shadow-2xl w-full max-w-sm p-8 text-center">
        <div class="w-16 h-16 bg-red-50 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
            </svg>
        </div>
        <h2 class="text-xl font-black text-zinc-900 mb-2">Delete Product?</h2>
        <p class="text-zinc-400 font-medium text-sm mb-6">This action cannot be undone. The product will be permanently removed.</p>
        <input type="hidden" id="deleteProductId">
        <input type="hidden" id="deleteImageUrl">
        <div class="flex gap-3">
            <button onclick="closeDeleteModal()"
                class="flex-1 py-3 rounded-xl border border-zinc-200 font-bold text-zinc-600 hover:bg-zinc-50 transition-all">
                Cancel
            </button>
            <button onclick="confirmDeleteAction()"
                class="flex-1 py-3 rounded-xl bg-red-500 hover:bg-red-600 text-white font-black transition-all active:scale-95">
                Yes, Delete
            </button>
        </div>
    </div>
</div>

<body class="bg-zinc-50 font-sans antialiased text-zinc-900">
    <%- include("partials/header") %>

    <div class="max-w-7xl mx-auto py-12 px-6 lg:px-8">

        <!-- Category Navigation -->
        <div class="flex gap-2 overflow-x-auto pb-4 mb-8 scrollbar-hide">
            <% categories.forEach(cat => { %>
            <a href="/?category=<%= cat.slug %>"
                class="whitespace-nowrap px-5 py-2.5 rounded-full text-sm font-bold transition-all
                <%= activeCategory === cat.slug ? 'bg-zinc-900 text-white shadow-lg' : 'bg-white text-zinc-600 border border-zinc-200 hover:border-zinc-400 hover:bg-zinc-50' %>">
                <%= cat.name %>
            </a>
            <% }) %>
        </div>

        <div class="flex items-end justify-between mb-10">
            <div>
                <% if (query) { %>
                    <span class="text-green-600 font-bold tracking-widest text-xs uppercase">Search Results</span>
                    <h1 class="font-extrabold text-4xl mt-1 tracking-tight text-zinc-900">
                        Results for "<%= query %>"
                    </h1>
                    <a href="/" class="text-sm font-bold text-zinc-400 hover:text-green-600 transition-colors inline-flex items-center mt-2">
                        <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path d="M10 19l-7-7m0 0l7-7m-7 7h18" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                        </svg>
                        Back to all products
                    </a>
                <% } else { %>
                    <span class="text-green-600 font-bold tracking-widest text-xs uppercase">Curated Collection</span>
                    <h1 class="font-extrabold text-4xl mt-1 tracking-tight text-zinc-900">Best Sellers</h1>
                <% } %>
            </div>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-10">
            <% if (products && products.length > 0) { %>

                <% products.forEach(product => { %>
                    <% const variants = product.product_variants || []; %>
                    <% const firstVariant = variants.find(v => (v.stock !== undefined ? v.stock : 99) > 0) || variants[0] || {}; %>
                    <% const qtyInCart = (firstVariant.id ? cartMap[firstVariant.id] : 0) || 0; %>
                    <% const stock = firstVariant.stock !== undefined ? firstVariant.stock : 99; %>
                    <% const isOutOfStock = variants.length > 0 && variants.every(v => (v.stock !== undefined ? v.stock : 99) === 0); %>

                    <div class="product group bg-white rounded-2xl border border-zinc-100 shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-300 overflow-hidden"
                        data-id="<%= product.id %>"
                        data-variant-id="<%= firstVariant.id || '' %>"
                        data-name="<%= product.name.replace(/"/g, '&quot;') %>"
                        data-category="<%= product.category %>"
                        data-price="<%= firstVariant.price || 0 %>"
                        data-stock="<%= stock %>"
                        data-variants="<%- JSON.stringify(variants.map(v => ({id: v.id, weight: v.weight, price: v.price, mrp: v.mrp || '', stock: v.stock}))).replace(/"/g, '&quot;') %>">

                        <div class="relative aspect-square overflow-hidden bg-zinc-100">
                            <% if (user && user.role === 'ADMIN') { %>
                            <div class="absolute top-3 right-3 z-10 flex flex-col gap-2">
                                <button onclick="confirmDelete('<%= product.id %>', '<%= product.image %>')"
                                    class="bg-red-500/90 hover:bg-red-600 backdrop-blur-sm text-white p-2 rounded-xl shadow-lg transition-all active:scale-90">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                            d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                                    </svg>
                                </button>
                                <button onclick="openEditModal('<%= product.id %>')"
                                    class="bg-blue-500/90 hover:bg-blue-600 backdrop-blur-sm text-white p-2 rounded-xl shadow-lg transition-all active:scale-90">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                            d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                                    </svg>
                                </button>
                            </div>
                            <% } %>

                            <img src="<%= product.image %>"
                                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500 <%= isOutOfStock ? 'opacity-50' : '' %>">

                            <% if (product.is_featured && !isOutOfStock) { %>
                            <div class="absolute top-3 left-3 bg-white/90 backdrop-blur-sm px-2 py-1 rounded-md shadow-sm">
                                <span class="text-[10px] font-bold text-zinc-600 uppercase tracking-wider">⭐ Best Seller</span>
                            </div>
                            <% } %>

                            <% if (isOutOfStock) { %>
                            <div class="absolute inset-0 flex items-center justify-center">
                                <span class="bg-black/70 text-white text-xs font-black px-4 py-2 rounded-xl uppercase tracking-widest">Out of Stock</span>
                            </div>
                            <% } else if (stock <= 3) { %>
                            <div class="absolute bottom-3 left-3 bg-orange-500 text-white px-2 py-1 rounded-md">
                                <span class="text-[10px] font-black">Only <%= stock %> left!</span>
                            </div>
                            <% } %>

                            <% if (firstVariant.mrp && firstVariant.mrp > firstVariant.price && !isOutOfStock) { %>
                            <div class="absolute bottom-3 right-3 bg-green-600 text-white px-2 py-1 rounded-md">
                                <span class="text-[10px] font-black">
                                    <%= Math.round((firstVariant.mrp - firstVariant.price) / firstVariant.mrp * 100) %>% OFF
                                </span>
                            </div>
                            <% } %>
                        </div>

                        <div class="p-5">
                            <div class="mb-3">
                                <% if (product.brand) { %>
                                <p class="text-[10px] font-black uppercase tracking-widest text-zinc-400 mb-0.5"><%= product.brand %></p>
                                <% } %>
                                <h3 class="text-base font-bold text-zinc-800 leading-tight"><%= product.name %></h3>
                            </div>

                            <!-- Variant selector — weight only, no price in dropdown -->
                            <% if (variants.length === 1) { %>
                            <!-- Single variant: just show the weight as a label -->
                            <div class="mb-3 px-1">
                                <span class="text-xs font-bold text-zinc-500 bg-zinc-50 border border-zinc-200 px-3 py-2 rounded-xl inline-block w-full">
                                    <%= firstVariant.weight %><%= ((firstVariant.stock !== undefined ? firstVariant.stock : 99) === 0) ? ' (Out of Stock)' : (firstVariant.stock <= 3 && firstVariant.stock > 0) ? ` (Only ${firstVariant.stock} left)` : '' %>
                                </span>
                            </div>
                            <% } else if (variants.length > 1) { %>
                            <div class="relative mb-3">
                                <select class="variant-select w-full bg-zinc-50 border border-zinc-200 p-2.5 pr-8 rounded-xl text-sm font-bold text-zinc-700 focus:outline-none focus:border-green-500 cursor-pointer appearance-none transition-all"
                                    onchange="onVariantChange(this)" <%= isOutOfStock ? 'disabled' : '' %>>
                                    <% variants.forEach((variant, i) => { %>
                                    <% const vStock = variant.stock !== undefined ? variant.stock : 99; %>
                                    <option
                                        value="<%= variant.id %>"
                                        data-price="<%= variant.price %>"
                                        data-mrp="<%= variant.mrp || '' %>"
                                        data-weight="<%= variant.weight %>"
                                        data-stock="<%= vStock %>"
                                        <%= variant.id === firstVariant.id ? 'selected' : '' %>
                                        <%= vStock === 0 ? 'disabled' : '' %>>
                                        <%= variant.weight %><%= vStock === 0 ? ' (Out of Stock)' : vStock <= 3 ? ` (Only ${vStock} left)` : '' %>
                                    </option>
                                    <% }) %>
                                </select>
                                <div class="pointer-events-none absolute inset-y-0 right-3 flex items-center">
                                    <svg class="w-4 h-4 text-zinc-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                                    </svg>
                                </div>
                            </div>
                            <% } %>

                            <div class="flex justify-between items-center pt-2 border-t border-zinc-50">
                                <div>
                                    <div class="flex items-baseline gap-2">
                                        <span class="variant-price text-xl font-black text-green-700">Rs. <%= firstVariant.price || 0 %></span>
                                        <% if (firstVariant.mrp && firstVariant.mrp > firstVariant.price) { %>
                                        <span class="variant-mrp text-xs text-zinc-400 line-through font-medium">Rs. <%= firstVariant.mrp %></span>
                                        <% } else { %>
                                        <span class="variant-mrp text-xs text-zinc-400 line-through font-medium hidden"></span>
                                        <% } %>
                                    </div>
                                    <% if (firstVariant.mrp && firstVariant.mrp > firstVariant.price) { %>
                                    <span class="variant-discount text-[10px] font-black text-green-600">
                                        Save Rs. <%= firstVariant.mrp - firstVariant.price %>
                                    </span>
                                    <% } else { %>
                                    <span class="variant-discount text-[10px] font-black text-green-600 hidden"></span>
                                    <% } %>
                                </div>

                                <div class="quantity-controls flex items-center">
                                    <% if (user && user.role === 'ADMIN') { %>
                                    <!-- Admin sees no cart controls -->
                                    <% } else if (isOutOfStock) { %>
                                    <button disabled class="out-of-stock-btn bg-zinc-200 text-zinc-400 px-4 py-2.5 rounded-xl text-xs font-bold cursor-not-allowed">
                                        Out of Stock
                                    </button>
                                    <% } else { %>
                                    <button disabled class="out-of-stock-btn hidden bg-zinc-200 text-zinc-400 px-4 py-2.5 rounded-xl text-xs font-bold cursor-not-allowed">
                                        Out of Stock
                                    </button>
                                    <button onclick="showCounter(this)"
                                        class="add-btn bg-zinc-900 hover:bg-green-700 text-white px-4 py-2.5 rounded-xl text-xs font-bold transition-all shadow-lg shadow-zinc-200 active:scale-95 <%= qtyInCart > 0 ? 'hidden' : '' %>">
                                        ADD
                                    </button>
                                    <div class="counter-control <%= qtyInCart > 0 ? 'flex' : 'hidden' %> items-center bg-zinc-900 text-white rounded-xl overflow-hidden shadow-lg shadow-zinc-200 transition-all">
                                        <button onclick="updateQty(this, -1)"
                                            class="px-3 py-2.5 hover:bg-zinc-800 text-sm font-bold transition-colors leading-none">-</button>
                                        <span class="qty-text px-2 py-2.5 font-bold text-xs w-8 text-center leading-none"><%= qtyInCart > 0 ? qtyInCart : 1 %></span>
                                        <button onclick="updateQty(this, 1)"
                                            class="px-3 py-2.5 hover:bg-zinc-800 text-sm font-bold transition-colors leading-none">+</button>
                                    </div>
                                    <% } %>
                                </div>
                            </div>
                        </div>
                    </div>
                <% }) %>

            <% } else { %>
                <div class="col-span-full py-20 text-center bg-white rounded-[4rem] border border-dashed border-zinc-200 shadow-inner">
                    <div class="inline-flex items-center justify-center w-24 h-24 bg-green-50 rounded-full mb-8 animate-pulse">
                        <svg class="w-12 h-12 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                                d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                        </svg>
                    </div>
                    <h2 class="text-3xl font-black text-zinc-900 tracking-tight">No results for "<%= query %>"</h2>
                    <p class="text-zinc-500 mt-3 max-w-sm mx-auto font-medium">
                        We couldn't find any products matching your search. Try a different keyword.
                    </p>
                    <div class="mt-10 flex gap-4 justify-center">
                        <a href="/" class="bg-zinc-900 text-white px-10 py-4 rounded-2xl font-black hover:bg-green-700 transition-all shadow-lg active:scale-95">
                            Browse All
                        </a>
                    </div>
                </div>
            <% } %>
        </div>
    </div>

    <!-- Edit Product Modal -->
    <div id="editModal" class="fixed inset-0 bg-black/50 backdrop-blur-sm z-50 hidden items-center justify-center p-4">
        <div class="bg-white rounded-3xl shadow-2xl w-full max-w-md p-8 max-h-[90vh] overflow-y-auto">
            <div class="flex items-center justify-between mb-6">
                <h2 class="text-xl font-black text-zinc-900">Edit Product</h2>
                <button onclick="closeEditModal()" class="text-zinc-400 hover:text-zinc-600 transition-colors">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                    </svg>
                </button>
            </div>

            <input type="hidden" id="editProductId">

            <div class="space-y-4">
                <div>
                    <label class="text-xs font-black uppercase tracking-widest text-zinc-400 block mb-1">Product Name</label>
                    <input type="text" id="editName"
                        class="w-full p-4 rounded-xl border border-zinc-200 outline-none focus:border-green-600 transition-all font-medium">
                </div>

                <div>
                    <label class="text-xs font-black uppercase tracking-widest text-zinc-400 block mb-1">Category</label>
                    <select id="editCategory"
                        class="w-full p-4 rounded-xl border border-zinc-200 outline-none focus:border-green-600 transition-all font-medium bg-white">
                        <% categories.forEach(cat => { %>
                            <% if (cat.slug !== 'all') { %>
                            <option value="<%= cat.slug %>"><%= cat.name %></option>
                            <% } %>
                        <% }) %>
                    </select>
                </div>

                <!-- Variant Stock Editor -->
                <div>
                    <label class="text-xs font-black uppercase tracking-widest text-zinc-400 block mb-2">Stock per Variant</label>
                    <div id="editVariantStocks" class="space-y-2">
                        <!-- populated by openEditModal() -->
                    </div>
                    <div id="newVariantRows" class="space-y-2 mt-2">
                        <!-- new variants appended here -->
                    </div>
                    <button type="button" onclick="addNewVariantRow()"
                        class="mt-2 w-full py-2 rounded-xl border border-dashed border-zinc-300 text-xs font-black text-zinc-400 hover:border-green-500 hover:text-green-600 transition-all">
                        + Add Variant
                    </button>
                </div>

                <div>
                    <label class="text-xs font-black uppercase tracking-widest text-zinc-400 block mb-1">
                        New Image <span class="text-zinc-300 font-normal normal-case">(optional)</span>
                    </label>
                    <input type="file" id="editImage" accept="image/*"
                        class="w-full p-3 rounded-xl border border-zinc-200 outline-none text-sm text-zinc-500">
                    <img id="editImagePreview" class="mt-3 w-full h-40 object-cover rounded-xl hidden">
                </div>
            </div>

            <div class="flex gap-3 mt-6">
                <button type="button" onclick="closeEditModal()"
                    class="flex-1 py-3 rounded-xl border border-zinc-200 font-bold text-zinc-600 hover:bg-zinc-50 transition-all">
                    Cancel
                </button>
                <button type="button" onclick="submitEdit()"
                    class="flex-1 py-3 rounded-xl bg-green-600 hover:bg-green-700 text-white font-black transition-all active:scale-95">
                    Save Changes
                </button>
            </div>
        </div>
    </div>

    <script>
        const IS_LOGGED_IN = <%= user ? 'true' : 'false' %>;
        const CART_MAP = <%- JSON.stringify(cartMap) %>;
    </script>
    <%- include("partials/footer") %>
</body>

</html>
